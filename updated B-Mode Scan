% Specify SeqControl structure arrays.
%  - Jump back to Flash start.
SeqControl(1).command = 'jump';
SeqControl(1).argument = 1;%10252;
SeqControl(2).command = 'timeToNextAcq';  % time between synthetic aperture acquisitions
SeqControl(2).argument = 220;  % 220 usec
SeqControl(3).command = 'timeToNextAcq';  % time between synthetic aperture acquisitions
SeqControl(3).argument = 30000;  % 30000 usec = 30msec time between frames
SeqControl(4).command = 'returnToMatlab';
%  - Jump back to scan start.
SeqControl(5).command = 'jump';
SeqControl(5).argument = 1;

% nsc = 5; % nsc is count of SeqControl objects

nsc = length(SeqControl)+1;

%SWE SeqControls - NEWADDITION
nsc = length(SeqControl)+1;
SeqControl(nsc).command = 'setTPCProfile';
SeqControl(nsc).condition = 'immediate';
SeqControl(nsc).argument = 1;
TPCprofile1 = nsc;  % store index
nsc = nsc+1;

SeqControl(nsc).command = 'setTPCProfile';
SeqControl(nsc).condition = 'immediate';
SeqControl(nsc).argument = 5;
TPCprofile5 = nsc;  % store index
nsc = nsc+1;

SeqControl(nsc).command = 'noop';
SeqControl(nsc).argument = 100000; % 100ms charging
noopCharge = nsc;   % store index
nsc = nsc+1;

SeqControl(nsc).command = 'timeToNextAcq';
SeqControl(nsc).argument = 500;   % 500us after push
afterPushSC = nsc;
nsc = nsc+1;

SeqControl(nsc).command = 'timeToNextAcq';
SeqControl(nsc).argument = 100;   % 100us PRF (10 kHz)
trackPRF = nsc;
nsc = nsc+1;

SeqControl(nsc).command = 'timeToNextEB';
SeqControl(nsc).argument = 200000; % 200ms between SWE frames
TTNEB = nsc;
nsc = nsc+1;

SeqControl(nsc).command = 'triggerOut';
triggerOutSC = nsc;
nsc = nsc+1;
%end NEWADDITION

% Specify Event structure arrays.
% n = 1;
% nStartFlashOnly = n;
