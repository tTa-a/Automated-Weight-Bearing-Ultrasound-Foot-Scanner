                   'rcvnum', 1, ...
                   'scaleFactor', 0.2, ...
                   'regionnum', 0, ...
                   'threadSync', 1), 1, P.numRays);
% - Set specific ReconInfo attributes.
ReconInfo(1).Pre = 'clearInterBuf';
for j = 1:P.numRays
    ReconInfo(j).txnum = j;
    ReconInfo(j).rcvnum = j;
    ReconInfo(j).regionnum = j;
end
ReconInfo(P.numRays).Post = 'IQ2IntensityImageBuf';

% SWE Recon Structures - NEWADDITION
Recon(2).senscutoff = 0.6;
Recon(2).pdatanum = 1;
Recon(2).rcvBufFrame = -1;
Recon(2).IntBufDest = [0,0];
Recon(2).ImgBufDest = [1,-1];
Recon(2).RINums = P.numRays+1;

Recon(3).senscutoff = 0.6;
Recon(3).pdatanum = 2;
Recon(3).rcvBufFrame = -1;
Recon(3).IntBufDest = [2,1];
Recon(3).ImgBufDest = [0,0];
Recon(3).RINums = (P.numRays+2):(P.numRays+1+na);

% B‑mode reference ReconInfo for SWE display
ReconInfo(P.numRays+1).mode = 'replaceIntensity';
ReconInfo(P.numRays+1).txnum = 1;
ReconInfo(P.numRays+1).rcvnum = numBmodeReceives + 1;
ReconInfo(P.numRays+1).regionnum = 1;

% IQ ReconInfo for SWE
for j = 1:na
    ReconInfo(P.numRays+1+j).mode = 'replaceIQ';
    ReconInfo(P.numRays+1+j).txnum = 1;
    ReconInfo(P.numRays+1+j).rcvnum = numBmodeReceives + j;
    ReconInfo(P.numRays+1+j).pagenum = j;
    ReconInfo(P.numRays+1+j).regionnum = 1;
end
%end NEWADDITION

% Specify Process structure array.
pers = 2;
Process(1).classname = 'Image';
Process(1).method = 'imageDisplay';
Process(1).Parameters = {'imgbufnum',1,...   % number of buffer to process.
                         'framenum',-1,...   % (-1 => lastFrame)
