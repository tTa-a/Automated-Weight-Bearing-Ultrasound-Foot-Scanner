% 
% n = n+1;
n = 1;
nStartFlashOnly = n;
for i = 1:Resource.RcvBuffer(1).numFrames
    for j = 1:P.numRays        % Acquire frame
        Event(n).info = 'Flash Frame';
        Event(n).tx = j;
        Event(n).rcv = P.numRays*(i-1)+j;
        Event(n).recon = 0;
        Event(n).process = 0;
        Event(n).seqControl = 2;
        n = n+1;
    end
    Event(n-1).seqControl = [3,nsc]; % modify last acquisition Event's seqControl
    SeqControl(nsc).command = 'transferToHost'; % transfer frame to host buffer
    
    Event(n).info = 'recon and process';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = 1;
    Event(n).process = 1;
    Event(n).seqControl = 0;
    if floor(i/frameRateFactor) == i/frameRateFactor     % Exit to Matlab every 1 frame reconstructed
        Event(n).seqControl = 4;
    end
    n = n+1;
end
nsc = nsc +1;
%% Jump Back to Collect Next Scan Position
Event(n).info       = 'Jump Back Flash';
Event(n).tx         = 0;
Event(n).rcv        = 0;
Event(n).recon      = 0;
Event(n).process    = 0;
Event(n).seqControl = nsc;
SeqControl(nsc).command = 'jump';
SeqControl(nsc).argument = nStartFlashOnly;

n = n+1;
nStartScan = n;
nsc = nsc + 1;
for motStep = 1:nSteps
    for i = 1:Resource.RcvBuffer(1).numFrames
        for j = 1:P.numRays        % Acquire frame
            Event(n).info = 'Flash Frame';
            Event(n).tx = j;
            Event(n).rcv = P.numRays*(i-1)+j;
            Event(n).recon = 0;
            Event(n).process = 0;
            Event(n).seqControl = 2;
            n = n+1;
        end
        Event(n-1).seqControl = [3,nsc]; % modify last acquisition Event's seqControl
        SeqControl(nsc).command = 'transferToHost'; % transfer frame to host buffer
        
        Event(n).info = 'recon and process';
        Event(n).tx = 0;
        Event(n).rcv = 0;
        Event(n).recon = 1;
        Event(n).process = 1;
        Event(n).seqControl = 0;
        if floor(i/frameRateFactor) == i/frameRateFactor     % Exit to Matlab every 1 frame reconstructed
            Event(n).seqControl = 4;
        end
        n = n+1;
    end

    if motStep>1 % Collect data on first position without moving motor
        %% Move Motor
        Event(n).info = 'Move Motor';
        Event(n).tx = 0;
        Event(n).rcv = 0;
        Event(n).recon = 0;
        Event(n).process = 2; % Call Move Motor Function movemotor
        Event(n).seqControl = 0;
        n = n+1;
    end

    Event(n).info    = 'Save IQ';
    Event(n).tx      = 0;
    Event(n).rcv     = 0;
    Event(n).recon   = 0;
    Event(n).process = 3;
    Event(n).seqControl = 0;
    n = n+1;
end

%SWE SCAN EVENTS - NEWADDITION
nStartSWE = n;  % Mark start of SWE scan events

for motStep = 1:nSteps
    % Switch to high power profile
    Event(n).info = 'Switch to profile 5';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = 0;
    Event(n).process = 0;
    Event(n).seqControl = TPCprofile5; 
    n = n+1;
    
    Event(n).info = 'Charge cap';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = 0;
    Event(n).process = 0;
    Event(n).seqControl = noopCharge; % noop (100ms)
    n = n+1;
    
    % Push transmit
    Event(n).info = 'Push transmit';
    Event(n).tx = P.numRays+1;
    Event(n).rcv = 0;
    Event(n).recon = 0;
    Event(n).process = 0;
    Event(n).seqControl = [afterPushSC, TTNEB];
    n = n+1;
    
    % Tracking acquisitions
    for j = 1:na
        Event(n).info = sprintf('Track %d', j);
        Event(n).tx = 1;
        Event(n).rcv = numBmodeReceives + (motStep-1)*na + j;
        Event(n).recon = 0;
        Event(n).process = 0;
        if j < na
            Event(n).seqControl = trackPRF;
        else
            Event(n).seqControl = 0;
        end
        n = n+1;
    end
    
    % Transfer to host
    Event(n).info = 'Transfer SWE data';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = 0;
    Event(n).process = 0;
    Event(n).seqControl = nsc;
    SeqControl(nsc).command = 'transferToHost';
    nsc = nsc+1;
    n = n+1;
    
    % Reconstruct
    Event(n).info = 'Recon SWE';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = [2,3];
    Event(n).process = 0;
    Event(n).seqControl = 0;
    n = n+1;
    
    % Process IQ (external function)
    Event(n).info = 'Process IQ';
    Event(n).tx = 0;
    Event(n).rcv = 0;
    Event(n).recon = 0;
    Event(n).process = 5;  % index of processIQ in Process list
    Event(n).seqControl = 0;
    n = n+1;
    
    % Move motor (except first position)
    if motStep > 1
        Event(n).info = 'Move Motor SWE';
        Event(n).tx = 0;
        Event(n).rcv = 0;
        Event(n).recon = 0;
        Event(n).process = 3;  % movemotor
        Event(n).seqControl = 0;
        n = n+1;
    end
    
    % Save SWE data
